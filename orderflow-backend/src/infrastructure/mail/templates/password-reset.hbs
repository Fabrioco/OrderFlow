<html>
  <head>
    <meta charset='UTF-8' />
    <title>Redefinição de Senha</title>
  </head>

  <body
    style='
      margin: 0;
      padding: 0;
      background-color: #0b1220;
      font-family: Inter, Arial, sans-serif;
      color: #e2e8f0;
    '
  >
    <table
      width='100%'
      cellpadding='0'
      cellspacing='0'
      style='padding: 40px 20px'
    >
      <tr>
        <td align='center'>
          <table
            width='100%'
            cellpadding='0'
            cellspacing='0'
            style='
              max-width: 520px;
              background-color: #0f172a;
              border: 1px solid #1e293b;
              border-radius: 12px;
              padding: 32px;
            '
          >
            <tr>
              <td align='left'>
                <h2
                  style='
                    margin: 0 0 16px 0;
                    font-size: 20px;
                    font-weight: 600;
                    color: #f8fafc;
                  '
                >
                  Olá,
                  <span style='color: #ff6b35'>{{name}}</span>
                  <br />
                  Você solicitou a redefinição de senha
                </h2>

                <p
                  style='
                    margin: 0 0 24px 0;
                    font-size: 14px;
                    color: #94a3b8;
                    line-height: 1.6;
                  '
                >
                  Utilize o token abaixo para redefinir sua senha. Este código
                  expira em
                  <strong style='color: #f87171;'>1 hora</strong>.
                </p>

                <!-- Token Box -->
                <div
                  style='
                    background-color: #111827;
                    border: 1px solid #1e293b;
                    border-radius: 10px;
                    padding: 20px;
                    text-align: center;
                    margin-bottom: 24px;
                  '
                >
                  <span
                    style='
                      display: inline-block;
                      font-size: 22px;
                      letter-spacing: 2px;
                      font-weight: 600;
                      color: #38bdf8;
                    '
                  >
                    {{token}}
                  </span>
                </div>

                <p
                  style='
                    margin: 0;
                    font-size: 12px;
                    color: #64748b;
                  '
                >
                  Se você não solicitou a redefinição de senha, ignore este
                  email.
                </p>
              </td>
            </tr>
          </table>

          <!-- Footer -->
          <p
            style='
              margin-top: 24px;
              font-size: 12px;
              color: #475569;
            '
          >
            ©
            {{year}}
            OrderFlow. Todos os direitos reservados.
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>